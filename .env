# ── SpectrumTrack Backend — Railway Environment Variables ─────────────────────
# IMPORTANT: Set ALL of these in Railway → your API service → Variables tab
# Never commit this file to git!

# Railway MySQL (use the INTERNAL hostname when both services are on Railway)
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=pkxjElBHgeXDRhtwAeGMfNKuKAGBElTQ
# IMPORTANT: must match the database you ran schema.sql in
# If you ran: CREATE DATABASE spectrumtrack; USE spectrumtrack; → use spectrumtrack
# If you kept Railway's default → use railway
DB_NAME=railway

# JWT — variable names MUST match exactly what auth.js reads
# Generate fresh values with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=spectrumtrack-super-secret-key-2024-CHANGE-ME
JWT_REFRESH_SECRET=spectrumtrack-refresh-secret-key-2024-CHANGE-ME-TOO

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

PORT=4000
NODE_ENV=production

# IMPORTANT: set this to your actual Railway frontend URL
# e.g. https://spectrumtrack-frontend-production.up.railway.app
FRONTEND_URL=https://spectrumtrack-frontend-production.up.railway.app/